# Database — get a free Neon or Supabase PostgreSQL URL
DATABASE_URL=postgresql://user:password@host:5432/midwestern_peptides

# Redis — get a free Upstash Redis URL
REDIS_URL=redis://localhost:6379

# Auth secrets — generate with: openssl rand -base64 32
JWT_SECRET=change_me_generate_random_secret
COOKIE_SECRET=change_me_generate_random_secret

# CORS — comma-separated origins
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# Medusa backend public URL
MEDUSA_BACKEND_URL=http://localhost:9000

# Stripe (optional for now, add when ready)
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# NOWPayments crypto (add when ready)
# NOWPAYMENTS_API_KEY=...
# NOWPAYMENTS_IPN_SECRET=...

# Admin user (used by seed script)
MEDUSA_ADMIN_EMAIL=admin@midwesternpeptides.com
MEDUSA_ADMIN_PASSWORD=change_me_before_production
