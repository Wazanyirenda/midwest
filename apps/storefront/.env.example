# Supabase — from supabase.com dashboard → project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe — required for card payments
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend — transactional email (order confirmations, shipping updates).
# Leave empty to disable sends (they no-op with a console warning).
RESEND_API_KEY=re_...
RESEND_FROM=Midwestern Peptides <orders@midwesternpeptides.com>

# Admin dashboard — comma-separated login emails allowed into /admin.
# Leave empty in dev to allow any signed-in user; REQUIRED in production.
ADMIN_EMAILS=owner@example.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
